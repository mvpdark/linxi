<?xml version="1.0" encoding="utf-8"?>
<!--
  灵犀 Android Manifest。

  说明：
  - package 属性在 AGP 8.x 已由 build.gradle.kts 的 namespace = "com.mvpdark.lingxi" 取代，
    故此处不再声明 package 属性。
  - 因入口类位于 Kotlin 包 top.mvpdark.lingxi.android（与 namespace 不同），
    application/activity 的 android:name 使用全限定类名。
  - usesCleartextTraffic 允许开发期访问 http 后端（10.0.2.2:8000）。
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!-- 保存图片到相册：仅 API 24-28 需要，API 29+ 通过 MediaStore 免权限 -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:name="top.mvpdark.lingxi.android.LingxiApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Lingxi"
        android:usesCleartextTraffic="true">

        <activity
            android:name="top.mvpdark.lingxi.android.MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- FileProvider：用于 APK 自动更新安装 -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
